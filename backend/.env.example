# Copy this file to backend/.env

# Choose: auto | ollama | groq | openrouter | claude | none
LLM_BACKEND=auto

# Cloud providers (optional)
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Optional model overrides
GROQ_MODEL=llama-3.3-70b-versatile
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

# Whisper settings
WHISPER_MODEL=small
WHISPER_COMPUTE_TYPE=int8
WHISPER_DEVICE=auto
WHISPER_BEAM_SIZE=5

# Live microphone chunking
LIVE_WHISPER_CHUNK_SEC=3.0

# --- Speech-to-text provider toggle ---
# whisper (local faster-whisper, default) | reson8 (cloud streaming)
STT_PROVIDER=whisper

# Reson8 settings (only required when STT_PROVIDER=reson8)
RESON8_API_KEY=
RESON8_ENDPOINT=wss://api.reson8.dev/v1/speech-to-text/realtime
RESON8_SAMPLE_RATE=16000
RESON8_MODEL=default
